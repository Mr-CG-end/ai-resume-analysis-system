APP_VERSION=0.1.0
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
# Optional: model request deadline in seconds (default: 20). Profile extraction
# shares this total budget across retries; matching applies it per attempt.
# AI_TIMEOUT_SECONDS=20
# Comma-separated explicit browser origins. Empty values and * are rejected.
CORS_ORIGINS=http://localhost:5173
# Optional: leave unset to disable Redis.
# REDIS_URL=redis://127.0.0.1:16379/0
# Optional: validated cache result lifetime in seconds (default: 86400).
# CACHE_TTL_SECONDS=86400
